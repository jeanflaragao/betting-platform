# -------------------------------
# Repository-wide ignores
# -------------------------------

# OS/editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Local env files and machine-specific overrides
.env
.env.*
*.local
*.bak

# Logs, temp files, runtime state
log/*
tmp/*
!/backend/log/.keep
!/backend/tmp/.keep

# Common build and test artifacts
coverage/
*.pid
*.seed
dump.rdb

# Ruby / Rails artifacts
.bundle/
vendor/bundle/
.byebug_history
.ruby-lsp/
.solargraph/
.solargraph.yml
.rubocop_cache/

# Rails credentials keys (never commit secrets)
backend/config/master.key
backend/config/credentials/*.key

# Rails local storage and compiled assets
backend/storage/*
!backend/storage/.keep
backend/tmp/storage/*
!backend/tmp/storage/.keep
backend/public/packs/
backend/public/packs-test/
backend/public/assets/
backend/public/uploads/
backend/public/system/

# SQLite files (if used locally)
*.sqlite3
*.sqlite3-journal

# Node/frontend artifacts
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker local overrides
docker-compose.override.yml
docker-compose.override.yaml
docker-sync.yml
